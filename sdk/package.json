{
  "name": "kodelet",
  "version": "0.0.0",
  "description": "TypeScript SDK for Kodelet agents and extensions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./test-harness": {
      "types": "./dist/test-harness.d.ts",
      "import": "./dist/test-harness.js"
    },
    "./task-progress": {
      "types": "./dist/task-progress.d.ts",
      "import": "./dist/task-progress.js"
    }
  },
  "bin": {
    "kodelet-extension-node": "dist/bin/kodelet-extension-node.js",
    "kodelet-mcp-install": "dist/extensions/mcp/install.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "node -e \"const fs=require('fs');const p='./dist/extensions/mcp/install.js';if(fs.existsSync(p))import(p).catch(e=>{console.error(e);process.exit(1)})\"",
    "test": "tsx --test src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mustache": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6",
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jingkaihe/kodelet.git",
    "directory": "sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
