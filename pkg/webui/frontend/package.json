{
  "name": "kodelet-webui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "lint": "biome lint . --vcs-enabled=true --vcs-client-kind=git --vcs-use-ignore-file=true --vcs-root=../../.. --css-parse-tailwind-directives=true --diagnostic-level=error --skip=lint/a11y --skip=lint/security/noDangerouslySetInnerHtml --skip=lint/style/useImportType --skip=lint/style/useNodejsImportProtocol --skip=lint/correctness/useParseIntRadix --skip=lint/complexity/noUselessFragments --skip=lint/suspicious/noArrayIndexKey --skip=lint/complexity/useOptionalChain --skip=lint/correctness/useExhaustiveDependencies --skip=lint/suspicious/noUnknownAtRules --skip=lint/suspicious/noShorthandPropertyOverrides",
    "lint:fix": "biome lint . --write --vcs-enabled=true --vcs-client-kind=git --vcs-use-ignore-file=true --vcs-root=../../.. --css-parse-tailwind-directives=true --diagnostic-level=error --skip=lint/a11y --skip=lint/security/noDangerouslySetInnerHtml --skip=lint/style/useImportType --skip=lint/style/useNodejsImportProtocol --skip=lint/correctness/useParseIntRadix --skip=lint/complexity/noUselessFragments --skip=lint/suspicious/noArrayIndexKey --skip=lint/complexity/useOptionalChain --skip=lint/correctness/useExhaustiveDependencies --skip=lint/suspicious/noUnknownAtRules --skip=lint/suspicious/noShorthandPropertyOverrides",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "clsx": "^2.1.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^1.14.0",
    "marked": "^9.1.6",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.10",
    "@types/prismjs": "^1.26.3",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.17",
    "daisyui": "^4.4.24",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.12",
    "storybook": "^10.4.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "vite": "^6.4.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}
