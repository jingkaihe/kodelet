{
  "name": "kodelet-desktop",
  "private": true,
  "description": "Electron shell for kodelet serve",
  "author": "Jingkai He",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "dev:local": "npm run build && electron . --kodelet-path ../bin/kodelet",
    "start": "npm run build && electron .",
    "check:version": "node scripts/check-version.cjs",
    "test": "npm run check:version && tsx --test src/test/*.test.ts",
    "package": "npm run check:version && npm run build && npx electron-builder --config electron-builder.config.js --publish never --config.mac.notarize=false --config.mac.identity=null",
    "package:ci": "npm run check:version && npm run build && npx electron-builder --config electron-builder.config.js --publish never"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2"
  },
  "build": {},
  "allowScripts": {
    "electron@39.8.8": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.0": true
  }
}
