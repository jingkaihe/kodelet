{
  "name": "kodelet-desktop",
  "version": "0.3.42-beta",
  "private": true,
  "description": "Electron shell for kodelet serve",
  "author": "Jingkai He",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && electron .",
    "dev:local": "npm run build && electron . --kodelet-path ../../bin/kodelet",
    "start": "npm run build && electron .",
    "test": "tsx --test src/test/*.test.ts",
    "package": "npm run build && electron-builder --config.mac.notarize=false --config.mac.identity=null"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "build": {
    "appId": "com.jingkaihe.kodelet.desktop",
    "productName": "Kodelet",
    "copyright": "Copyright \u00a9 Jingkai He",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../bin",
        "to": "bin",
        "filter": [
          "kodelet*"
        ]
      },
      {
        "from": "../VERSION.txt",
        "to": ".",
        "filter": [
          "VERSION.txt"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dir",
        "zip"
      ]
    },
    "linux": {
      "category": "Development",
      "icon": "assets/icon.png",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "portable"
      ]
    }
  }
}
